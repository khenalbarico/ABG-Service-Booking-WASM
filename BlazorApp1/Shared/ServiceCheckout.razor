@inject AppDb      Db
@inject AppPayment Payment
@inject AppEmailer Emailer

<div class="checkout-container">

    @if (isLoading)
    {
        <div class="loading-overlay">
            <div class="loading-box">
                <div class="spinner"></div>
                <p>Processing your request...</p>
            </div>
        </div>
    }

    @if (!showForm && !showSuccess && !showQr && !showNailsRules && !showConsentForm)
    {
        <div class="checkout-header fade-in">
            <div class="checkout-badge">Booking Summary</div>
            <h2>Your Booking</h2>
            <p>Review your selected services before confirming your appointment</p>
        </div>

        @if (Request.ClientServices.Count == 0)
        {
            <div class="empty-state fade-in">
                <div class="empty-icon">✦</div>
                <p>No services selected yet</p>
            </div>
        }
        else
        {
            <div class="booking-list fade-in">
                @foreach (var s in Request.ClientServices)
                {
                    <div class="booking-card slide-up">
                        <div class="booking-left">
                            <div class="booking-name">@s.ServiceName</div>
                            <div class="booking-details">@s.ServiceDetails</div>
                            <div class="booking-meta">
                                <span>@(BranchNames.TryGetValue(s.Branch, out var branchName) ? branchName : s.Branch.ToString())</span>
                                <span>@s.ServiceDate.ToString("MMMM dd, yyyy")</span>
                                <span>@s.ServiceDate.ToString("hh:mm tt")</span>
                            </div>
                        </div>

                        <div class="booking-right">
                            <div class="booking-price">₱@s.ServiceCost</div>
                            <button class="remove-btn" @onclick="() => Remove(s.ServiceUid)">Remove</button>
                        </div>
                    </div>
                }
            </div>

            <div class="summary-card fade-in">
                <div class="summary-row">
                    <span>Total Amount</span>
                    <strong>₱@Request.ClientServices.Sum(x => x.ServiceCost)</strong>
                </div>

                <button class="primary-btn" @onclick="OpenForm">
                    Confirm Appointment
                </button>
            </div>
        }

        <button class="secondary-btn" @onclick="Close">Close</button>
    }

    @if (showForm)
    {
        <div class="form-section fade-in">
            <div class="checkout-header">
                <div class="checkout-badge">Client Details</div>
                <h3>Client Information</h3>
                <p>Please complete the details below to continue to payment</p>
            </div>

            <EditForm Model="Request.ClientInformation" OnValidSubmit="Submit">
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-summary" />

                <div class="form-grid">
                    <div class="input-group">
                        <label>First Name</label>
                        <InputText class="form-input" placeholder="Enter first name" @bind-Value="Request.ClientInformation.FirstName" />
                        <ValidationMessage For="@(() => Request.ClientInformation.FirstName)" />
                    </div>

                    <div class="input-group">
                        <label>Last Name</label>
                        <InputText class="form-input" placeholder="Enter last name" @bind-Value="Request.ClientInformation.LastName" />
                        <ValidationMessage For="@(() => Request.ClientInformation.LastName)" />
                    </div>

                    <div class="input-group">
                        <label>Email</label>
                        <InputText class="form-input" placeholder="Enter email address" @bind-Value="Request.ClientInformation.Email" />
                        <ValidationMessage For="@(() => Request.ClientInformation.Email)" />
                    </div>

                    <div class="input-group">
                        <label>Contact Number</label>
                        <InputText class="form-input" placeholder="Enter contact number" @bind-Value="Request.ClientInformation.ContactNumber" />
                        <ValidationMessage For="@(() => Request.ClientInformation.ContactNumber)" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(consumerError))
                {
                    <div class="validation-error">@consumerError</div>
                }

                <div class="form-actions">
                    <button type="submit" class="primary-btn">Proceed</button>
                    <button type="button" class="secondary-btn" @onclick="CloseForm">Back</button>
                </div>
            </EditForm>
        </div>
    }

    @if (showNailsRules)
    {
        <div class="checkout-panel fade-in">
            <div class="checkout-header">
                <div class="checkout-badge">Policy Review</div>
                <h3>Nails Service Rules</h3>
                <p>Please review the rules below before proceeding to payment.</p>
            </div>

            <NailsSvcRules OnProceed="HandleNailsRulesAccepted" OnBack="BackFromNailsRules" />
        </div>
    }

    @if (showConsentForm)
    {
        <div class="checkout-panel fade-in">
            <div class="checkout-header">
                <div class="checkout-badge">Consent Review</div>
                <h3>Lash & Brow Consent Form</h3>
                <p>Please review and complete the form below before proceeding to payment.</p>
            </div>

            <ConsentForm OnProceed="HandleConsentAccepted" OnBack="BackFromConsentForm" />
        </div>
    }

    @if (showQr)
    {
        <div class="qr-section fade-in">
            <div class="checkout-badge">Payment</div>
            <h3>Scan to Pay</h3>

            @if (!string.IsNullOrWhiteSpace(qrImageUrl))
            {
                <div class="qr-card">
                    <img src="@qrImageUrl" class="qr-image" alt="QR Payment" />
                </div>
            }

            <div class="waiting-box">
                <div class="spinner small"></div>
                <p>Waiting for payment confirmation...</p>
                <span>
                    For a smooth transaction, please ensure you have a stable internet connection. Avoid closing or refreshing this page while your payment is being processed.
                </span>
            </div>

            <button class="secondary-btn" @onclick="CancelPayment">Cancel Transaction</button>
        </div>
    }

    @if (showSuccess)
    {
        <div class="success-section fade-in">
            <div class="success-icon">✓</div>
            <h2>Booking Confirmed</h2>
            <p>Your appointment has been successfully booked.</p>
            <button class="primary-btn" @onclick="Finish">Done</button>
        </div>
    }

</div>

@code {
    [Parameter] public ClientRequest Request { get; set; } = new();
    [Parameter] public EventCallback<string> OnRemove { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }
    [Parameter] public EventCallback OnSchedulesChanged { get; set; }

    bool showForm;
    bool showSuccess;
    bool showQr;
    bool showNailsRules;
    bool showConsentForm;
    bool isLoading;

    bool nailsRulesAccepted;
    bool consentAccepted;

    string? qrImageUrl;
    string? paymentIntentId;
    CancellationTokenSource? pollCts;

    string? consumerError;

    async Task Remove(string uid)
        => await OnRemove.InvokeAsync(uid);

    void OpenForm() => showForm = true;

    void CloseForm()
    {
        consumerError = null;
        showForm = false;
    }

    async Task Submit()
    {
        consumerError = null;

        var info = Request.ClientInformation;

        info.BookingDate     = DateTime.Now;
        info.ClientBookingId = $"{DateTime.Now:MMddyy}-{Random.Shared.Next(10000000, 99999999)}";

        var needsNailsRules = RequiresNailsRules();
        var needsConsentForm = RequiresConsentForm();

        showForm = false;

        if (needsNailsRules && !nailsRulesAccepted)
        {
            showNailsRules = true;
            showConsentForm = false;
            return;
        }

        if (needsConsentForm && !consentAccepted)
        {
            showNailsRules = false;
            showConsentForm = true;
            return;
        }

        await StartPaymentAsync();
    }

    private bool RequiresNailsRules()
    {
        return Request.ClientServices.Any(x =>
            ContainsKeyword(x.ServiceName, "nail") ||
            ContainsKeyword(x.ServiceDetails, "nail"));
    }

    private bool RequiresConsentForm()
    {
        return Request.ClientServices.Any(x =>
            ContainsKeyword(x.ServiceName, "lash") ||
            ContainsKeyword(x.ServiceName, "brow") ||
            ContainsKeyword(x.ServiceDetails, "lash") ||
            ContainsKeyword(x.ServiceDetails, "brow"));
    }

    private static bool ContainsKeyword(string? value, string keyword)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(keyword, StringComparison.OrdinalIgnoreCase);
    }

    private async Task HandleNailsRulesAccepted()
    {
        nailsRulesAccepted = true;
        showNailsRules = false;

        if (RequiresConsentForm() && !consentAccepted)
        {
            showConsentForm = true;
            return;
        }

        await StartPaymentAsync();
    }

    private void BackFromNailsRules()
    {
        showNailsRules = false;
        showForm = true;
    }

    private async Task HandleConsentAccepted()
    {
        consentAccepted = true;
        showConsentForm = false;
        await StartPaymentAsync();
    }

    private void BackFromConsentForm()
    {
        showConsentForm = false;

        if (RequiresNailsRules() && nailsRulesAccepted)
        {
            showNailsRules = true;
            return;
        }

        showForm = true;
    }

    private async Task StartPaymentAsync()
    {
        isLoading = true;
        StateHasChanged();

                     await Db.PostClientRequestAsync(Request);
        var result = await Payment.CreateQrphChargeAsync(Request);

        paymentIntentId = result.PaymentIntentId;
        qrImageUrl      = result.QrImageUrl;

        isLoading = false;
        showQr    = true;

        pollCts = new CancellationTokenSource();
        _ = PollPaymentStatus(pollCts.Token);
    }

    private async Task PollPaymentStatus(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                var status = await Payment.GetPaymentIntentStatusAsync(paymentIntentId!);

                if (status == "succeeded")
                {
                    pollCts?.Cancel();

                    Request.Status = ClientStatus.Paid;

                    await Emailer.SendEmailAsync(Request);
                    await OnSchedulesChanged.InvokeAsync();

                    showForm = false;
                    showQr = false;
                    showNailsRules = false;
                    showConsentForm = false;
                    paymentIntentId = null;
                    qrImageUrl = null;
                    showSuccess = true;

                    await InvokeAsync(StateHasChanged);
                    break;
                }

                await Task.Delay(3000, ct);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void CancelPayment()
    {
        pollCts?.Cancel();
        showQr = false;
        paymentIntentId = null;
        qrImageUrl = null;
    }

    private async Task Close()
    {
        pollCts?.Cancel();
        await OnClose.InvokeAsync();
    }

    private async Task Finish()
    {
        pollCts?.Cancel();
        showSuccess = false;
        showForm = false;
        showQr = false;
        showNailsRules = false;
        showConsentForm = false;
        paymentIntentId = null;
        qrImageUrl = null;
        consumerError = null;
        nailsRulesAccepted = false;
        consentAccepted = false;
        await OnCompleted.InvokeAsync();
    }
}