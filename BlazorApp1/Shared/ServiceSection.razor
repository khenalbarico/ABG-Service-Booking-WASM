<section class="service-section">
    <div class="section-header">
        <div>
            <div class="section-kicker">Category</div>
            <h2>@Title</h2>
        </div>
    </div>

    <div class="service-cards">
        @foreach (var svc in Services)
        {
            var cardKey = GetCardKey(svc);
            var isBooked = BookedUids.Contains(cardKey);
            var hasBranch = HasSelectedBranch(cardKey);
            var hasDate = HasSelectedDate(cardKey);

            <article class="service-card @(svc.ScheduleSlots.IsAvailable ? "" : "service-card-disabled")" @key="cardKey">
                <div class="service-top">
                    <div class="service-title-wrap">
                        <div class="service-name">@svc.Details</div>
                        <div class="service-subtitle">@Title treatment</div>
                    </div>

                    <div class="service-price">₱@svc.Cost</div>
                </div>

                <div class="field-group">
                    <label>Select Branch</label>
                    <select class="field-input"
                            value="@GetSelectedBranchValue(cardKey)"
                            @onchange="e => OnBranchChanged(cardKey, e.Value?.ToString())">
                        <option value="">Choose branch</option>
                        @foreach (var branch in Enum.GetValues<ServiceBranch>())
                        {
                            <option value="@branch.ToString()">@GetBranchLabel(branch)</option>
                        }
                    </select>
                </div>

                @if (svc.Designs?.Count > 0)
                {
                    <div class="field-group">
                        <label>Design</label>
                        <select class="field-input" @bind="designSelections[cardKey]">
                            @foreach (var d in svc.Designs)
                            {
                                <option value="@d.DesignName">@d.DesignName</option>
                            }
                        </select>

                        @{
                            var selected = svc.Designs.FirstOrDefault(x => x.DesignName == designSelections[cardKey]);
                        }

                        @if (selected != null)
                        {
                            <div class="selected-design-name">
                                Selected: <span>@selected.DesignName</span>
                            </div>

                            <div class="design-gallery">
                                @foreach (var img in selected.ImageUrls)
                                {
                                    var imageUrl = GetImageUrl(img);
                                    <button type="button" class="design-image-card" @onclick="() => OpenImagePreview(imageUrl, selected.DesignName)">
                                        <img src="@imageUrl" alt="@selected.DesignName" />
                                        <div class="design-image-overlay">
                                            <span>View</span>
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }

                @if (hasBranch)
                {
                    <div class="field-group reveal-block">
                        <label>Select Date</label>

                        <div class="calendar-shell">
                            <div class="calendar-header">
                                <button type="button" class="calendar-nav" @onclick="() => ChangeMonth(cardKey, -1)">‹</button>
                                <span>@GetMonthLabel(cardKey)</span>
                                <button type="button" class="calendar-nav" @onclick="() => ChangeMonth(cardKey, 1)">›</button>
                            </div>

                            <div class="weekdays">
                                <span>Sun</span>
                                <span>Mon</span>
                                <span>Tue</span>
                                <span>Wed</span>
                                <span>Thu</span>
                                <span>Fri</span>
                                <span>Sat</span>
                            </div>

                            <div class="calendar-grid">
                                @foreach (var day in GetCalendarDays(svc, cardKey))
                                {
                                    <button class="day-button @(day.IsCurrentMonth ? "" : "outside-month") @(day.IsAllowed ? "allowed" : "blocked") @(IsSelectedDate(cardKey, day.Date) ? "selected" : "")"
                                            disabled="@(!day.IsAllowed || isBooked || day.Date.Date < DateTime.Today)"
                                            title="@day.Title"
                                            @onclick="() => SelectDate(cardKey, day.Date)">
                                        @day.Date.Day
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="availability-note">
                            Available days: @string.Join(", ", svc.ScheduleSlots.DaySlots)
                        </div>
                    </div>
                }

                @if (hasDate)
                {
                    <div class="field-group reveal-block">
                        <label>Select Time</label>

                        <select class="field-input" value="@GetSelectedTime(cardKey)" @onchange="e => OnTimeChanged(cardKey, e.Value?.ToString())">
                            <option value="">Choose time</option>
                            @foreach (var t in svc.ScheduleSlots.TimeSlots)
                            {
                                var slotStatus = GetTimeSlotStatus(svc, cardKey, t);
                                <option value="@t" disabled="@(slotStatus != TimeSlotStatus.Available)">@GetTimeSlotLabel(svc, cardKey, t)</option>
                            }
                        </select>

                        @if (HasSelectedDate(cardKey))
                        {
                            var selectedTime = GetSelectedTime(cardKey);
                            var selectedStatus = string.IsNullOrWhiteSpace(selectedTime)
                            ? TimeSlotStatus.Available
                            : GetTimeSlotStatus(svc, cardKey, selectedTime);

                            if (selectedStatus == TimeSlotStatus.BookedByYou)
                            {
                                var conflict = GetCurrentBookingConflict(cardKey, SelectedDates[cardKey], selectedTime);
                                var serviceLabel = conflict is null
                                ? "another service"
                                : (!string.IsNullOrWhiteSpace(conflict.ServiceDetails) ? conflict.ServiceDetails : conflict.ServiceName);

                                <div class="slot-status-note slot-status-note-conflict">
                                    This time is not available because you already booked <strong>@serviceLabel</strong> on @SelectedDates[cardKey].ToString("MMMM dd, yyyy") at @selectedTime.
                                </div>
                            }
                            else if (selectedStatus == TimeSlotStatus.Full)
                            {
                                <div class="slot-status-note slot-status-note-full">
                                    @GetFullSlotMessage(svc, selectedTime)
                                </div>
                            }
                        }
                    </div>
                }

                <div class="service-footer">
                    <button class="book-button"
                            disabled="@(!svc.ScheduleSlots.IsAvailable || isBooked || !HasSelectedBranch(cardKey) || !HasSelectedDate(cardKey) || !HasAvailableSelectedTime(svc, cardKey))"
                            @onclick="() => Book(svc, cardKey)">
                        @(isBooked ? "Already Added" : "Add to Booking")
                    </button>
                </div>
            </article>
        }
    </div>
</section>

@if (showImagePreview)
{
    <div class="design-modal-backdrop" @onclick="CloseImagePreview">
        <div class="design-modal" @onclick:stopPropagation="true">
            <button type="button" class="design-modal-close" @onclick="CloseImagePreview">×</button>
            <div class="design-modal-title">@previewTitle</div>
            <div class="design-modal-image-wrap">
                <img src="@previewImageUrl" alt="@previewTitle" class="design-modal-image" />
            </div>
        </div>
    </div>
}