@using WasmCore1.Utilities
<div class="services-page">
    <div class="services-header">
        <div>
            <div class="page-badge">Service Manager</div>
            <h1>Services Administration</h1>
            <p>View, add, update, and delete all service records stored in Firebase.</p>
        </div>

        <button class="add-btn" @onclick="OpenCreateModal">+ Add New Service</button>
    </div>

    @if (IsLoading)
    {
        <div class="loading-panel">
            <div class="loading-spinner"></div>
            <div class="loading-text">Loading services...</div>
        </div>
    }
    else
    {
        <div class="toolbar-card">
            <div class="toolbar-row">
                <select class="filter-select" @bind="_selectedCategory">
                    <option value="All">All Categories</option>
                    <option value="Nails">Nails</option>
                    <option value="Lash">Lash</option>
                    <option value="Eyebrows">Eyebrows</option>
                    <option value="Footspa">Footspa</option>
                </select>

                <input class="search-box"
                       placeholder="Search UID, details..."
                       @bind="_searchTerm"
                       @bind:event="oninput" />

                <button class="clear-btn" @onclick="ClearFilters">Clear</button>
            </div>
        </div>

        <div class="service-grid">
            @if (FilteredServices.Any())
            {
                @foreach (var item in FilteredServices)
                {
                    <div class="service-card">
                        <div class="service-card-head">
                            <div>
                                <div class="service-category">@item.Category</div>
                                <h3>@item.Service.Details</h3>
                                <div class="service-uid">@item.Service.Uid</div>
                            </div>
                            <div class="service-price">₱@item.Service.Cost.ToString("N2")</div>
                        </div>

                        <div class="service-body">
                            <div class="meta-row">
                                <span class="meta-label">Designs</span>
                                <span class="meta-value">@FormatDesigns(item.Service.Designs)</span>
                            </div>

                            <div class="meta-row">
                                <span class="meta-label">Available</span>
                                <span class="meta-value">@(item.Service.ScheduleSlots?.IsAvailable == true ? "Yes" : "No")</span>
                            </div>
                        </div>

                        <div class="service-actions">
                            <button class="edit-btn" @onclick="() => OpenEditModal(item)">Edit Service</button>
                            <button class="delete-btn" @onclick="() => OpenDeleteModal(item)">Delete Service</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state-card">
                    <div class="empty-title">No services found</div>
                    <div class="empty-text">Try changing the category or search term.</div>
                </div>
            }
        </div>
    }
</div>

@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-panel" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <div class="page-badge">@(_isEditMode ? "Edit Service" : "New Service")</div>
                    <h2>@(_isEditMode ? "Modify Service" : "Create Service")</h2>
                </div>
                <button class="close-btn" @onclick="CloseModal">✕</button>
            </div>

            <div class="form-grid">
                <div class="form-field">
                    <label>Service Category <span>*</span></label>
                    <select class="form-input" @bind="_form.ServiceName" disabled="@_isEditMode">
                        <option value="">Select category</option>
                        <option value="Nails">Nails</option>
                        <option value="Lash">Lash</option>
                        <option value="Eyebrows">Eyebrows</option>
                        <option value="Footspa">Footspa</option>
                    </select>
                </div>

                <div class="form-field">
                    <label>UID</label>
                    <input class="form-input" value="@(_isEditMode? _form.ServiceUid: "Auto-generated when saved")" disabled />
                </div>

                <div class="form-field wide">
                    <label>Details <span>*</span></label>
                    <input class="form-input" @bind="_form.ServiceDetails" />
                </div>

                <div class="form-field">
                    <label>Cost <span>*</span></label>
                    <input class="form-input" type="number" step="0.01" @bind="_form.ServiceCost" />
                </div>
            </div>

            @if (IsNailsCategorySelected)
            {
                <div class="design-section">
                    <div class="design-head">
                        <h3>Nail Designs</h3>
                        <label class="switch-row">
                            <input type="checkbox" @bind="_addNailDesigns" />
                            <span>Add default nail designs</span>
                        </label>
                    </div>

                    @if (_addNailDesigns)
                    {
                        <div class="design-preview-grid">
                            @foreach (var design in GetDefaultNailDesigns())
                            {
                                <div class="design-preview-card">
                                    <div class="design-name">@design.DesignName</div>
                                    <div class="design-count">@design.ImageUrls.Count image(s)</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <div class="slot-section">
                <div class="slot-head">
                    <h3>Schedule Availability</h3>
                    <label class="switch-row">
                        <input type="checkbox" @bind="_isAvailable" />
                        <span>Is Available</span>
                    </label>
                </div>

                <div class="picker-group">
                    <div class="picker-title">Select Days</div>
                    <div class="chip-select-wrap">
                        @foreach (var day in Slots.AllDays)
                        {
                            <button type="button"
                                    class="choice-chip @(IsDaySelected(day) ? "selected" : "")"
                                    @onclick="() => ToggleDay(day)">
                                @day
                            </button>
                        }
                    </div>
                </div>

                <div class="picker-group">
                    <div class="picker-title picker-title-row">
                        <span>Select Time Slots</span>
                        <button type="button" class="quick-fill-btn" @onclick="ApplyStoreHours">
                            Use Store Hours
                        </button>
                    </div>

                    <div class="chip-select-wrap">
                        @foreach (var time in StoreHours)
                        {
                            <button type="button"
                                    class="choice-chip alt @(IsTimeSelected(time) ? "selected" : "")"
                                    @onclick="() => ToggleTime(time)">
                                @time
                            </button>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="form-error">@_errorMessage</div>
            }

            <div class="modal-actions">
                <button class="ghost-btn" @onclick="CloseModal">Cancel</button>
                <button class="save-btn" @onclick="HandleSaveServiceAsync" disabled="@_isSaving">
                    @(_isSaving ? "Saving..." : (_isEditMode ? "Update Service" : "Create Service"))
                </button>
            </div>
        </div>
    </div>
}

@if (_showDeleteModal && _selectedDeleteItem is not null)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="delete-modal-panel" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <div class="page-badge danger-badge">Delete Service</div>
                    <h2>Confirm Deletion</h2>
                </div>
                <button class="close-btn" @onclick="CloseDeleteModal">✕</button>
            </div>

            <div class="delete-summary">
                <div class="delete-title">@_selectedDeleteItem.Service.Details</div>
                <div class="delete-meta">Category: @_selectedDeleteItem.Category</div>
                <div class="delete-meta">UID: @_selectedDeleteItem.Service.Uid</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_deleteErrorMessage))
            {
                <div class="form-error">@_deleteErrorMessage</div>
            }

            <div class="modal-actions">
                <button class="ghost-btn" @onclick="CloseDeleteModal">Cancel</button>
                <button class="confirm-delete-btn" @onclick="HandleDeleteServiceAsync" disabled="@_isDeleting">
                    @(_isDeleting ? "Deleting..." : "Delete Service")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private sealed class ServiceListItem
    {
        public string Category { get; set; } = "";
        public BaseSvcStructure Service { get; set; } = new();
    }

    [Parameter] public List<BaseSvcStructure> Nails { get; set; } = [];
    [Parameter] public List<BaseSvcStructure> Lashes { get; set; } = [];
    [Parameter] public List<BaseSvcStructure> Eyebrows { get; set; } = [];
    [Parameter] public List<BaseSvcStructure> Footspa { get; set; } = [];
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public Func<string, BaseSvcStructure, Task>? SaveServiceAsync { get; set; }
    [Parameter] public Func<string, string, Task>? DeleteServiceAsync { get; set; }
    [Parameter] public ScheduleCfg ScheduleCfg { get; set; } = new();

    private List<ServiceListItem> _services = [];
    public Days Slots = new();
    private bool _showModal;
    private bool _isEditMode;
    private bool _isSaving;
    private bool _addNailDesigns;
    private bool _showDeleteModal;
    private bool _isDeleting;
    private string _selectedCategory = "All";
    private string _searchTerm = string.Empty;
    private string _errorMessage = string.Empty;
    private string _deleteErrorMessage = string.Empty;

    private ClientService _form = new();
    private List<string> _selectedDays = [];
    private List<string> _selectedTimeSlots = [];
    private bool _isAvailable = true;
    private ServiceListItem? _selectedDeleteItem;

    private bool IsNailsCategorySelected =>
        string.Equals(_form.ServiceName, "Nails", StringComparison.OrdinalIgnoreCase);

    private List<string> StoreHours =>
        ScheduleCfg?.StoreHours ?? [];

    private IEnumerable<ServiceListItem> FilteredServices =>
        _services.Where(x =>
            (_selectedCategory == "All" || x.Category.Equals(_selectedCategory, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(_searchTerm)
                || (x.Service.Uid?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                || (x.Service.Details?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)));

    protected override void OnParametersSet()
    {
        _services =
        [
            .. (Nails ?? []).Select(x => new ServiceListItem { Category = "Nails", Service = x }),
            .. (Lashes ?? []).Select(x => new ServiceListItem { Category = "Lash", Service = x }),
            .. (Eyebrows ?? []).Select(x => new ServiceListItem { Category = "Eyebrows", Service = x }),
            .. (Footspa ?? []).Select(x => new ServiceListItem { Category = "Footspa", Service = x })
        ];

        _services = _services
            .OrderBy(x => x.Category)
            .ThenBy(x => x.Service.Details)
            .ToList();
    }

    private void OpenCreateModal()
    {
        _isEditMode = false;
        _errorMessage = string.Empty;

        _form = new ClientService
        {
            ServiceUid = string.Empty,
            ServiceName = string.Empty,
            ServiceDesign = string.Empty,
            ServiceDetails = string.Empty,
            ServiceCost = 0
        };

        _selectedDays = [];
        _selectedTimeSlots = [];
        _isAvailable = true;
        _addNailDesigns = false;

        _showModal = true;
    }

    private void OpenEditModal(ServiceListItem item)
    {
        _isEditMode = true;
        _errorMessage = string.Empty;

        _form = new ClientService
        {
            ServiceUid = item.Service.Uid,
            ServiceName = item.Category,
            ServiceDetails = item.Service.Details,
            ServiceCost = item.Service.Cost,
            ServiceDesign = string.Empty
        };

        _selectedDays = item.Service.ScheduleSlots?.DaySlots?.ToList() ?? [];
        _selectedTimeSlots = item.Service.ScheduleSlots?.TimeSlots?.ToList() ?? [];
        _isAvailable = item.Service.ScheduleSlots?.IsAvailable ?? true;
        _addNailDesigns = item.Service.Designs?.Any() == true;

        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _errorMessage = string.Empty;
    }

    private void OpenDeleteModal(ServiceListItem item)
    {
        _selectedDeleteItem = item;
        _deleteErrorMessage = string.Empty;
        _showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        _showDeleteModal = false;
        _isDeleting = false;
        _deleteErrorMessage = string.Empty;
        _selectedDeleteItem = null;
    }

    private bool IsDaySelected(string day) =>
        _selectedDays.Contains(day, StringComparer.OrdinalIgnoreCase);

    private bool IsTimeSelected(string time) =>
        _selectedTimeSlots.Contains(time, StringComparer.OrdinalIgnoreCase);

    private void ToggleDay(string day)
    {
        var existing = _selectedDays.FirstOrDefault(x => x.Equals(day, StringComparison.OrdinalIgnoreCase));

        if (existing is not null)
            _selectedDays.Remove(existing);
        else
            _selectedDays.Add(day);
    }

    private void ToggleTime(string time)
    {
        var existing = _selectedTimeSlots.FirstOrDefault(x => x.Equals(time, StringComparison.OrdinalIgnoreCase));

        if (existing is not null)
            _selectedTimeSlots.Remove(existing);
        else
            _selectedTimeSlots.Add(time);
    }

    private void ApplyStoreHours()
    {
        _selectedTimeSlots = StoreHours.ToList();
    }

    private void ClearFilters()
    {
        _selectedCategory = "All";
        _searchTerm = string.Empty;
    }

    private async Task HandleSaveServiceAsync()
    {
        _errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(_form.ServiceName))
        {
            _errorMessage = "Please select a service category.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_form.ServiceDetails))
        {
            _errorMessage = "Please enter the service details.";
            return;
        }

        if (_form.ServiceCost < 0)
        {
            _errorMessage = "Service cost cannot be negative.";
            return;
        }

        if (SaveServiceAsync is null)
        {
            _errorMessage = "Save handler is not available.";
            return;
        }

        try
        {
            _isSaving = true;

            var category = _form.ServiceName.NormalizeCategory();

            var uid = _isEditMode
                ? _form.ServiceUid
                : category.GenerateUid();

            var service = new BaseSvcStructure
            {
                Uid = uid,
                Details = _form.ServiceDetails.Trim(),
                Cost = _form.ServiceCost,
                Designs = BuildDesigns(),
                ScheduleSlots = new BaseSchedSlot
                {
                    IsAvailable = _isAvailable,
                    DaySlots = _selectedDays.ToList(),
                    TimeSlots = _selectedTimeSlots.ToList()
                }
            };

            await SaveServiceAsync.Invoke(category, service);
            CloseModal();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to save service: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleDeleteServiceAsync()
    {
        _deleteErrorMessage = string.Empty;

        if (_selectedDeleteItem is null || string.IsNullOrWhiteSpace(_selectedDeleteItem.Service.Uid))
        {
            _deleteErrorMessage = "Unable to identify the selected service.";
            return;
        }

        if (DeleteServiceAsync is null)
        {
            _deleteErrorMessage = "Delete handler is not available.";
            return;
        }

        try
        {
            _isDeleting = true;
            await DeleteServiceAsync.Invoke(_selectedDeleteItem.Category, _selectedDeleteItem.Service.Uid);
            CloseDeleteModal();
        }
        catch (Exception ex)
        {
            _deleteErrorMessage = $"Unable to delete service: {ex.Message}";
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private List<BaseDesign> BuildDesigns()
    {
        if (!IsNailsCategorySelected || !_addNailDesigns)
            return [];

        return GetDefaultNailDesigns();
    }

    private static List<BaseDesign> GetDefaultNailDesigns()
    {
        return Enum.GetValues<ServiceDesigns>()
            .Select(design => new BaseDesign
            {
                DesignName = design.ToString(),
                ImageUrls = ImageUrls.TryGetValue(design, out var urls)
                    ? urls.ToList()
                    : []
            })
            .ToList();
    }

    private static string FormatDesigns(List<BaseDesign>? designs)
    {
        if (designs is null || designs.Count == 0)
            return "-";

        return $"{designs.Count} design(s)";
    }
}