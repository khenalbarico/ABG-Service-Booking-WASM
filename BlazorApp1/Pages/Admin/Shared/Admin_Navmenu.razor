@inject AdminAuthState    AdminAuthState
@inject NavigationManager NavigationManager

<div class="nav-wrapper">
    <div class="brand-section">
        <div class="brand-icon">A</div>
        <div class="brand-text">
            <div class="brand-title">Admin Panel</div>
            <div class="brand-subtitle">Management Console</div>
        </div>
    </div>

    <div class="nav-group">
        <button type="button"
                class="nav-item @(CurrentPage == "dashboard" ? "active" : "")"
                @onclick='() => ChangePage("dashboard")'>
            <span class="nav-item-icon">◫</span>
            <span class="nav-item-text">Dashboard</span>
        </button>

        <button type="button"
                class="nav-item @(CurrentPage == "services" ? "active" : "")"
                @onclick='() => ChangePage("services")'>
            <span class="nav-item-icon">✦</span>
            <span class="nav-item-text">Services</span>
        </button>
    </div>

    <div class="nav-footer">
        <div class="nav-user-label">Logged in as</div>
        <div class="nav-user">@AdminAuthState.Email</div>
        <button type="button" class="logout-btn" @onclick="Logout">Sign Out</button>
    </div>
</div>

@code {
    [Parameter] public string CurrentPage { get; set; } = "dashboard";
    [Parameter] public EventCallback<string> CurrentPageChanged { get; set; }

    private async Task ChangePage(string page)
    {
        if (CurrentPageChanged.HasDelegate)
            await CurrentPageChanged.InvokeAsync(page);
    }

    private void Logout()
    {
        AdminAuthState.IsAuthenticated = false;
        AdminAuthState.Email = string.Empty;
        NavigationManager.NavigateTo("/", false);
    }
}

<style>
    .nav-wrapper {
        height: 100%;
        padding: 28px 18px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .brand-section {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 18px;
        border-radius: 22px;
        background: linear-gradient(135deg, rgba(125, 94, 255, 0.18), rgba(0, 194, 255, 0.08));
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.22);
    }

    .brand-icon {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #7c4dff, #00c6ff);
        color: white;
        font-size: 1.2rem;
        font-weight: 700;
        box-shadow: 0 12px 24px rgba(124, 77, 255, 0.35);
    }

    .brand-text {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .brand-title {
        font-size: 1rem;
        font-weight: 700;
        color: #f8faff;
    }

    .brand-subtitle {
        font-size: 0.82rem;
        color: #98a5c6;
    }

    .nav-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    .nav-item {
        width: 100%;
        border: 1px solid transparent;
        background: rgba(255, 255, 255, 0.03);
        color: #dbe6ff;
        border-radius: 18px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.96rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.22s ease;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
    }

        .nav-item:hover {
            transform: translateY(-1px);
            border-color: rgba(255, 255, 255, 0.08);
            background: rgba(255, 255, 255, 0.06);
        }

        .nav-item.active {
            background: linear-gradient(135deg, rgba(124, 77, 255, 0.28), rgba(0, 198, 255, 0.16));
            border-color: rgba(124, 77, 255, 0.4);
            color: #ffffff;
            box-shadow: 0 16px 30px rgba(39, 51, 89, 0.28);
        }

    .nav-item-icon {
        width: 22px;
        display: inline-flex;
        justify-content: center;
        font-size: 1rem;
    }

    .nav-item-text {
        flex: 1;
        text-align: left;
    }

    .nav-footer {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 16px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .nav-user-label {
        font-size: 0.8rem;
        color: #8fa3ca;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .nav-user {
        color: #eef2ff;
        font-size: 0.92rem;
        font-weight: 600;
        word-break: break-word;
    }

    .logout-btn {
        width: 100%;
        border: none;
        border-radius: 16px;
        padding: 12px 14px;
        background: linear-gradient(135deg, rgba(255, 77, 109, 0.9), rgba(255, 126, 95, 0.9));
        color: white;
        font-size: 0.92rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s ease;
        margin-top: 4px;
    }

        .logout-btn:hover {
            transform: translateY(-1px);
        }
</style>